# ─────────────────────────────────────────────────────────────────────────────
# RQM Telegram Navigation Bot — configuration
# Copy to `.env` and fill in. On the server set these as real env vars.
# ─────────────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather (the bot must be admin of the channel).
BOT_TOKEN=

# Channel chat id for the Bot API. Private channel internal id is 3131929652,
# so the Bot API id is -100 + that = -1003131929652.
# If unsure, run `python -m scripts.whoami` and post in the channel to discover it.
CHANNEL_CHAT_ID=-1003131929652

# Comma-separated Telegram user ids allowed to use admin features.
# Find yours by messaging the bot and running /id, or via @userinfobot.
OWNER_USER_IDS=

# Telegraph access token. Create once with `python -m scripts.setup_telegraph`.
TELEGRAPH_TOKEN=
TELEGRAPH_AUTHOR=Переводы RQM
TELEGRAPH_AUTHOR_URL=

# Public HTTPS URL where the Mini App frontend is served (the host's domain).
# e.g. https://rqm-nav.fly.dev  — used for the web_app button and CORS.
WEBAPP_URL=

# Optional proxy for reaching api.telegram.org (useful from RU networks where
# the Bot API is throttled/blocked). HTTP or SOCKS5, e.g.:
#   TELEGRAM_PROXY=socks5://127.0.0.1:1080
#   TELEGRAM_PROXY=http://user:pass@host:3128
# Leave empty to connect directly (e.g. on a foreign server, or with a VPN on).
TELEGRAM_PROXY=

# Host/port for the built-in aiohttp server (API + static Mini App).
HOST=0.0.0.0
PORT=8080

# SQLite database path. In production point this at the persistent volume,
# e.g. /data/rqm.db on Fly.io / Railway / Oracle volume.
DB_PATH=./data/rqm.db

# Path to the Telegram export used for the one-time structural backfill.
EXPORT_HTML=./ChatExport/messages.html

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
