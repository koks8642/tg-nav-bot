# Config for the ISOLATED TEST container (docker-compose.test.yml).
# Copy to `.env.test` on the server and fill in. Keep it 0600.
#
# CRITICAL: BOT_TOKEN here must be a SECOND bot from @BotFather, NOT the
# production bot's token. Two bots polling the same token break each other.

# Second test bot token from @BotFather. Set its privacy mode to DISABLED,
# then add it to a test group as a member (admin not required for chat).
BOT_TOKEN=

# Gemini key (same one is fine — the test bot is the only heavy user here).
AI_GEMINI_KEY=

# Your Telegram user id (and Kimchi's), comma-separated. In a test group with
# no RQM channel, admin rights for /ai commands come ONLY from this list.
OWNER_USER_IDS=

# Dummy channel id — the test bot is not a channel admin, so the watcher never
# fires. Leaving the prod value is harmless (it simply sees no channel posts),
# but a dummy keeps intent clear.
CHANNEL_CHAT_ID=-1000000000000

# Leave empty: the test bot creates its OWN throwaway Telegraph account, so it
# can never touch the production Telegraph pages.
TELEGRAPH_TOKEN=

# No proxy needed on the foreign server.
TELEGRAM_PROXY=

LOG_LEVEL=INFO
